<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>edit </title>
</head>
<body>
    <form action="/listing/<%= listing._id %>?_method=PUT" method="post">
    <input type="text" name="listing[title]" value="<%= listing.title %>">
    <br><br>
    <textarea name="listing[description]"></textarea>
    <br><br>
    <input type="text" name="listing[img]" value="<%= listing.img %>">
    <br><br>
    <input type="number" name="listing[price]" value="<%= listing.price %>">
    <br><br>
    <input type="text" name="listing[country]" value="<%= listing.country %>" >
    <br><br>
    <input type="text" name="listing[location]" value="<%= listing.location %>" >
    <br><br>
    <button>update</button>
    </form>
</body>
</html>