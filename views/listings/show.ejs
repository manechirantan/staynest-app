<% layout('./layouts/common.ejs') %>
<div class="row mt-3">
  <div class="col-8 offset-3">
    <h3>Listing Details:</h3>
  </div>
  <div class="card col-6 offset-3 show-card">
    <img
      src="<%=listings.image.url%>"
      class="card-img-top show-img"
      alt="..."
    />
    <div class="card-body">
      <p class="card-text">
        <b><%=listings.title%></b>
        <br />
        <%=listings.description%>
        <br />
        &#8377; <%=Number(listings.price).toLocaleString('en-IN')%>
        <br />
        <%=listings.location%>
        <br />
        <%=listings.country%>
      </p>
    </div>
  </div>
</div>
<div class="btns offset-3">
  <form action="/listing/<%=listings._id%>/edit">
    <button class="btn btn-dark offset-0 edit-btn">edit</button>
  </form>
    <form action="/listing/<%=listings._id%>?_method=DELETE" method="post">
    <button class="btn btn-dark offset-2">delete</button>
    <br><br>
    </form>
</div>

