<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>create Hotel</title>
</head>
<body>
    <h3>create new listings</h3>
    <form action="/listing" method="post">
    <input type="text" name="listing[title]" placeholder="enter title ">
    <br><br>
    <textarea name="listing[description]"></textarea>
    <br><br>
    <input type="text" name="listing[image][url]" placeholder="enter image link ">
    <br><br>
    <input type="number" name="listing[price]" placeholder="enter price">
    <br><br>
    <input type="text" name="listing[country]" placeholder="enter country" >
    <br><br>
    <input type="text" name="listing[location]" placeholder="enter location" >
    <br><br>
    <button>create</button>
    </form>
</body>
</html>