<% layout('./layouts/common.ejs') %>
<body>
    <h3>All listings</h3>
 <div class="row row-cols-lg-6 row-cols-md-2 row-cols-sm-1 g-3">
 <% for(let list of listings){ %>
  <a href="/listing/<%=list._id%>" class="listing-link">
 <div class="card col">
 <img src="<%=list.image.url%>" class="card-img-top" alt="..." style="height: 12rem; width:500px;" >
 <div class="card-body">
 <div class="card-img-overlay"></div>
 <p class="card-text"><b><%=list.title%></b>
     <br>
    &#8377;<%=Number(list.price).toLocaleString('en-IN')%>/Night
</div>
</div>
</a>
 <% } %>


 </div>

</body>
